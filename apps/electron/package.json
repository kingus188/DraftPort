{
  "name": "draftport-electron",
  "version": "1.0.0",
  "description": "DraftPort - 面向多平台发布的 Markdown 内容编辑器",
  "main": "dist/main.js",
  "homepage": "https://draftport.app",
  "author": "DraftPort Team",
  "scripts": {
    "build": "rimraf dist && tsc",
    "test": "rimraf dist && tsc && node --test dist/**/*.test.js",
    "dev": "rimraf dist && tsc && electron .",
    "start": "electron .",
    "build:mac": "npm run build && electron-builder --mac -c electron-builder.json",
    "build:win": "npm run build && electron-builder --win -c electron-builder.json",
    "build:linux": "npm run build && electron-builder --linux -c electron-builder.json"
  },
  "keywords": [
    "markdown",
    "wechat",
    "editor"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "rimraf": "^6.0.0",
    "typescript": "^5.0.0"
  }
}
